<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_complyo</name>
    <author>Complyo</author>
    <authorEmail>support@complyo.tech</authorEmail>
    <authorUrl>https://complyo.tech</authorUrl>
    <creationDate>2026-04</creationDate>
    <copyright>Copyright (C) 2026 Complyo. All rights reserved.</copyright>
    <license>GPL-2.0-or-later</license>
    <version>2.0.0</version>
    <description>PLG_SYSTEM_COMPLYO_DESCRIPTION</description>

    <files>
        <filename plugin="complyo">complyo.php</filename>
        <folder>language</folder>
    </files>

    <languages>
        <language tag="de-DE">language/de-DE/plg_system_complyo.ini</language>
        <language tag="de-DE">language/de-DE/plg_system_complyo.sys.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_complyo.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_complyo.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic" label="PLG_SYSTEM_COMPLYO_FIELDSET_BASIC">

                <field
                    name="site_id"
                    type="text"
                    label="PLG_SYSTEM_COMPLYO_SITE_ID_LABEL"
                    description="PLG_SYSTEM_COMPLYO_SITE_ID_DESC"
                    default=""
                    size="40"
                    filter="string"
                />

                <field
                    name="enable_cookie_banner"
                    type="radio"
                    label="PLG_SYSTEM_COMPLYO_COOKIE_LABEL"
                    description="PLG_SYSTEM_COMPLYO_COOKIE_DESC"
                    default="1"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="enable_tcf"
                    type="radio"
                    label="PLG_SYSTEM_COMPLYO_TCF_LABEL"
                    description="PLG_SYSTEM_COMPLYO_TCF_DESC"
                    default="0"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field
                    name="enable_accessibility"
                    type="radio"
                    label="PLG_SYSTEM_COMPLYO_A11Y_LABEL"
                    description="PLG_SYSTEM_COMPLYO_A11Y_DESC"
                    default="0"
                    layout="joomla.form.field.radio.switcher"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

            </fieldset>
        </fields>
    </config>
</extension>
